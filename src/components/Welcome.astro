---
import Card from '@/components/Card.astro';
import background from '@/assets/background.svg';
---

<main class='container'>
  <img id='background' src={background.src} alt='Background' />
  <div class='hero'>
    <svg
      width='6rem'
      class='logo'
      viewBox='0 0 101 89'
      xmlns='http://www.w3.org/2000/svg'
      aria-hidden='true'
      ><path
        fill-rule='evenodd'
        clip-rule='evenodd'
        d='M56.5622 3.50001C53.8679 -1.16665 47.1321 -1.16664 44.4378 3.50002L1.56955 77.75C-1.12475 82.4167 2.24311 88.25 7.63171 88.25H93.3682C98.7568 88.25 102.125 82.4167 99.4304 77.75L56.5622 3.50001ZM55.7073 26.0979C53.403 22.0719 47.597 22.0719 45.2926 26.0979L22.7781 65.4336C19.4845 71.188 26.581 77.2452 31.7467 73.0889L46.7387 61.0263C48.9349 59.2593 52.065 59.2593 54.2612 61.0263L69.2532 73.0888C74.419 77.2452 81.5155 71.188 78.2218 65.4336L55.7073 26.0979Z'
      ></path></svg
    >
    <h1>Welcome to <span class='emphasis-text'>Altitude</span></h1>
  </div>
  <p class='instructions'>
    To get started, open the directory <code>src/pages/index.astro</code> and replace
    the <code>Welcome.astro</code> component.<br />
  </p>
  <ul role='list' class='link-card-grid'>
    <Card
      href='https://thgaltitude.com/docs/platform'
      title='Documentation'
      body='Master Altitude effortlessly with our concise and comprehensive documentation. Explore and gain valuable insights to optimize your proficiency.'
    />
    <Card
      href='https://thgaltitude.com/products/cli'
      title='CLI'
      body='Unleash the full potential of your development process with our powerful CLI, designed to streamline your workflow and enhance productivity.'
    />
    <Card
      href='https://thgaltitude.com/products/astro-integration'
      title='Integrations'
      body='Discover limitless possibilities with our versatile Astro integrations, tailored to fit any path you choose.'
    />
    <Card
      href='https://thgaltitude.com/products/browser-components'
      title='Browser Components'
      body='Explore our extensive library of components, designed to elevate your development experience and streamline your workflow.'
    />
    <Card
      href='https://thgaltitude.com/kits'
      title='Starter Kits'
      body='Discover our exceptional collection of meticulously crafted starter kits, thoughtfully designed to cater to a wide range of frameworks.'
    />
    <Card
      href='https://thgaltitude.com/blog'
      title='Blog'
      body='Find out the latest news, updates and insights from the THG Altitude team.'
    />
  </ul>
</main>

<style>
  h1 {
    font-size: 2.5rem;
    font-weight: 400;
    margin: 1.5rem 0 0 0;
    text-align: center;
  }

  #background {
    position: absolute;
    top: 0;
    left: 0;
    z-index: -1;
    filter: blur(min(10vw, 120px));
  }

  .container {
    margin: auto;
    padding: 1.5rem;
    max-width: 800px;
    position: relative;
  }
  .logo {
    margin-right: 20px;
    fill: var(--primary-colour);
  }
  .instructions {
    line-height: 1.6;
    margin: 1.75rem 0;
    padding: 1.75rem;
    border-radius: 0.4rem;
    background-color: var(--box-bg);
  }
  .instructions code {
    font-size: 0.875em;
    font-weight: bold;
    border-radius: 4px;
    padding: 0.3em 0.45em;
    background-color: var(--code-bg);
    border: 1px solid var(--code-border);
  }
  .instructions strong {
    font-weight: 600;
  }
  .link-card-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(30ch, 1fr));
    gap: 1.75rem;
    padding: 0;
  }
  .hero {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    margin-top: 4em;
    margin-bottom: 4em;
  }
  .emphasis-text {
    font-weight: 600;
  }
</style>
