---
export interface Props {
  title: string;
  body: string;
  href: string;
}

const { href, title, body } = Astro.props;
---

<li class='link-card'>
  <a href={href}>
    <h2>
      {title}
      <span>&rarr;</span>
    </h2>
    <p>
      {body}
    </p>
  </a>
</li>
<style>
  .link-card {
    list-style: none;
    display: flex;
    background-color: var(--card-bg);
    border: var(--card-border);
    border-radius: 0.6rem;
  }

  .link-card > a {
    width: 100%;
    text-decoration: none;
    line-height: 1.4;
    padding: 1.75rem;
    border-radius: 0.35rem;
  }
  h2 {
    margin: 0;
    font-size: 1.15rem;
    font-weight: 600;
    color: var(--primary-colour);
  }
  p {
    margin-top: 0.5rem;
    margin-bottom: 0;
    color: #727272;
  }
</style>
