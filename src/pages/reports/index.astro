---
import '@/styles/design-system.css';

const reports = [
  {
    slug: 'myprotein-protein-plp-2026-06-04',
    name: 'Protein Powder & Protein Shakes — Myprotein PLP',
    date: '4 June 2026',
    url: 'https://www.myprotein.com/c/nutrition/protein/',
    health: 'AMBER' as const,
    healthLabel: 'Some Issues',
  },
  {
    slug: 'myprotein-clothing-hub-2026-06-02',
    name: 'Myprotein Clothing Hub',
    date: '2 June 2026',
    url: 'https://www.myprotein.com/c/clothing/',
    health: 'AMBER' as const,
    healthLabel: 'Some Issues',
  },
  {
    slug: 'myprotein-homepage-2026-06-02',
    name: 'Myprotein Homepage',
    date: '2 June 2026',
    url: 'https://www.myprotein.com/',
    health: 'AMBER' as const,
    healthLabel: 'Conversion Risk',
  },
  {
    slug: 'myprotein-impact-whey-2026-06-01',
    name: 'Impact Whey Protein Milkshake — Myprotein PDP',
    date: '1 June 2026',
    url: 'https://www.myprotein.com/sports-nutrition/impact-whey-protein/10530943.html',
    health: 'AMBER' as const,
    healthLabel: 'Conversion Risk',
  },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>UX Audit Reports</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  </head>
  <body>
    <header class="page-header">
      <div class="header-inner">
        <span class="logo">UX Audit</span>
      </div>
    </header>
    <main class="page-main">
      <div class="page-content">
        <h1 class="page-title">Reports</h1>
        <ul class="report-list">
          {reports.map((r) => (
            <li class="report-card">
              <a href={`/reports/${r.slug}`} class="report-link">
                <div class="report-info">
                  <span class="report-name">{r.name}</span>
                  <span class="report-date">{r.date}</span>
                </div>
                <div class="report-right">
                  <span class={`health-pill health-pill--${r.health.toLowerCase()}`}>{r.healthLabel}</span>
                  <span class="report-arrow">→</span>
                </div>
              </a>
            </li>
          ))}
        </ul>
      </div>
    </main>
  </body>
</html>

<style>
  *, *::before, *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  body {
    font-family: var(--font-body);
    background-color: var(--color-bg-page);
    color: var(--color-text-body);
    min-height: 100vh;
    -webkit-font-smoothing: antialiased;
  }

  .page-header {
    background-color: var(--color-primary);
    padding: 14px 24px;
  }

  .header-inner {
    max-width: 860px;
    margin: 0 auto;
  }

  .logo {
    color: var(--color-mint);
    font-size: 15px;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }

  .page-main {
    padding: 36px 24px 80px;
  }

  .page-content {
    max-width: 860px;
    margin: 0 auto;
  }

  .page-title {
    font-size: 28px;
    font-weight: 800;
    color: var(--color-text-heading);
    margin-bottom: 28px;
  }

  .report-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .report-card {
    background: var(--color-bg-card);
    border: var(--card-border);
    border-radius: var(--radius-card);
    box-shadow: var(--card-shadow);
    transition: box-shadow 0.15s, transform 0.15s;
  }

  .report-card:hover {
    box-shadow: 0 4px 16px rgba(0, 57, 66, 0.12);
    transform: translateY(-1px);
  }

  .report-link {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding: 18px 20px;
    text-decoration: none;
    color: inherit;
  }

  .report-info {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .report-name {
    font-size: 15px;
    font-weight: 600;
    color: var(--color-text-heading);
    line-height: 1.3;
  }

  .report-date {
    font-size: 12px;
    color: var(--color-text-body);
    opacity: 0.7;
  }

  .report-right {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-shrink: 0;
  }

  .health-pill {
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    padding: 4px 12px;
    border-radius: var(--radius-pill);
  }

  .health-pill--green { background: rgba(0, 120, 49, 0.12); color: var(--color-priority-low); }
  .health-pill--amber { background: rgba(221, 89, 43, 0.12); color: var(--color-priority-medium); }
  .health-pill--red   { background: rgba(217, 66, 15, 0.12); color: var(--color-priority-high); }

  .report-arrow {
    font-size: 16px;
    color: var(--color-text-heading);
    opacity: 0.4;
  }
</style>
