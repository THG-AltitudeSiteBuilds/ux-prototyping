---
import ReportLayout from '@/components/ReportLayout.astro';

const reports: Array<{
  title: string;
  competitor: string;
  pageType: string;
  date: string;
  slug: string;
  opportunityCount: number | 'None';
}> = [
  {
    title: 'Product Detail Page — TPW, Optimum Nutrition, Healf, Huel',
    competitor: 'TPW · ON · Healf · Huel',
    pageType: 'Product Detail Page',
    date: '2026-06-08',
    slug: 'pdp-competitor-analysis-2026-06-08',
    opportunityCount: 9,
  },
];
---

<ReportLayout title="Competitor Analysis Reports">

  <section class="page-intro">
    <h1 class="page-h1">Competitor Analysis</h1>
    <p class="page-subtitle">
      UX and conversion intelligence gathered from competitor pages.
      Each report identifies specific patterns worth considering for Myprotein — or confirms
      where we already lead.
    </p>
  </section>

  {reports.length === 0 ? (
    <p class="empty-state">No competitor reports yet. Run your first analysis to get started.</p>
  ) : (
    <div class="report-grid">
      {reports.map(report => (
        <a href={`/reports/competitors/${report.slug}`} class="report-card">
          <div class="report-card-header">
            <span class="report-competitor">{report.competitor}</span>
            <span class="report-page-type">{report.pageType}</span>
          </div>
          <h2 class="report-title">{report.title}</h2>
          <div class="report-footer">
            <span class="report-date">{report.date}</span>
            <span class={`report-opportunities ${report.opportunityCount === 'None' ? 'opportunities--none' : 'opportunities--found'}`}>
              {report.opportunityCount === 'None'
                ? 'No gaps found'
                : `${report.opportunityCount} ${report.opportunityCount === 1 ? 'opportunity' : 'opportunities'}`}
            </span>
          </div>
        </a>
      ))}
    </div>
  )}

</ReportLayout>

<style>
  .page-intro { margin-bottom: 48px; }
  .page-h1 { font-size: 28px; font-weight: 800; color: var(--color-text-heading); margin-bottom: 10px; }
  .page-subtitle { font-size: 15px; line-height: 1.7; color: var(--color-text-body); max-width: 600px; opacity: 0.8; }

  .empty-state { font-size: 14px; color: var(--color-text-body); opacity: 0.5; font-style: italic; }

  .report-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 20px;
  }

  .report-card {
    display: block;
    border: 1px solid rgba(0, 57, 66, 0.12);
    border-radius: 12px;
    padding: 20px;
    text-decoration: none;
    background: var(--color-bg-card, #fff);
    transition: border-color 0.15s, box-shadow 0.15s;
  }

  .report-card:hover {
    border-color: rgba(0, 57, 66, 0.3);
    box-shadow: 0 4px 16px rgba(0, 57, 66, 0.08);
  }

  .report-card-header {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 10px;
  }

  .report-competitor {
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--color-text-heading);
    opacity: 0.55;
  }

  .report-page-type {
    font-size: 11px;
    color: var(--color-text-body);
    opacity: 0.4;
  }

  .report-page-type::before { content: '·'; margin-right: 8px; }

  .report-title {
    font-size: 15px;
    font-weight: 700;
    color: var(--color-text-heading);
    line-height: 1.35;
    margin: 0 0 16px 0;
  }

  .report-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .report-date {
    font-size: 12px;
    color: var(--color-text-body);
    opacity: 0.45;
  }

  .report-opportunities {
    font-size: 12px;
    font-weight: 600;
    padding: 3px 10px;
    border-radius: 9999px;
  }

  .opportunities--found {
    background: #E8F5E9;
    color: #2E7D32;
  }

  .opportunities--none {
    background: #F5F5F5;
    color: #757575;
  }
</style>
